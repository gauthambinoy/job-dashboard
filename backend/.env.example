# Database Configuration
# For local development:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/job_dashboard
# For AWS RDS (production):
# DATABASE_URL=postgresql://username:password@your-rds-endpoint.amazonaws.com:5432/job_dashboard
DATABASE_URL=

# Server Configuration
API_PORT=5000
NODE_ENV=development

# JWT Configuration - Generate a secure key for production
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL for CORS configuration
# Local: http://localhost:3000
# Production: https://your-vercel-url.vercel.app
FRONTEND_URL=http://localhost:3000

# External API Keys
INDEED_API_KEY=your_indeed_api_key
LINKEDIN_API_KEY=your_linkedin_api_key
