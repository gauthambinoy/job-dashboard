# Database Configuration
# Local example:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lazyscaper
# Production examples: Railway Postgres, Supabase Postgres, Neon, AWS RDS, etc.

# Server Configuration
API_PORT=5000
NODE_ENV=development

# JWT Configuration - Generate a secure key for production
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL for CORS configuration
# Local: http://localhost:3000
# Production: https://your-vercel-url.vercel.app
FRONTEND_URL=http://localhost:3000

# External API Keys (optional; leave blank for free unauthenticated sources)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
RAPIDAPI_KEY=

# Legacy placeholders for older scraper experiments
INDEED_API_KEY=
LINKEDIN_API_KEY=
