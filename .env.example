# LazyScaper - Environment Variables Template
# Copy this file to .env and fill in ALL values before running docker compose.

# ============================================================
# DATABASE
# ============================================================

# Full connection string used directly by the backend.
# In Docker Compose the host is "postgres" (the service name).
# For local dev outside Docker use "localhost".
# For managed DBs (RDS, Railway, Supabase, etc.) paste their URL here.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/lazyscaper

# Individual fields used by the postgres Docker service
DB_USER=postgres
DB_PASSWORD=postgres          # CHANGE IN PRODUCTION
DB_NAME=lazyscaper
DB_PORT=5432                  # host-side port binding

# Optional Postgres init flags (passed to initdb)
# POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=C

# ============================================================
# BACKEND / API SERVER
# ============================================================

NODE_ENV=development          # set to "production" in prod
API_PORT=5000

# Generate a strong secret before deploying:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev-secret-change-this-in-production

# How long access tokens remain valid (e.g. 15m, 1h, 7d)
JWT_EXPIRES_IN=15m

# ============================================================
# CORS / FRONTEND ORIGIN
# ============================================================

# Backend uses this to set the Access-Control-Allow-Origin header.
# Development
FRONTEND_URL=http://localhost:3000

# Production examples:
# FRONTEND_URL=https://app.yourdomain.com
# FRONTEND_URL=https://lazyscaper.vercel.app

# ============================================================
# FRONTEND (Next.js)
# ============================================================

# The browser-visible URL of the backend API.
# Must be set at *build time* (Next.js inlines NEXT_PUBLIC_* variables).
# Development
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Production examples:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
# NEXT_PUBLIC_API_URL=https://lazyscaper-api.railway.app/api

# Port the Next.js container listens on (host-side binding)
FRONTEND_PORT=3000

# Opt out of Next.js anonymous telemetry
NEXT_TELEMETRY_DISABLED=1

# ============================================================
# EXTERNAL API KEYS (optional)
# ============================================================

# Indeed Rapid API key (leave blank if not using)
INDEED_API_KEY=

# LinkedIn API key (leave blank if not using)
LINKEDIN_API_KEY=
